<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.chart.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox alignment="CENTER" prefHeight="418.0" prefWidth="504.0" spacing="20.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.oscilloscope.HelloController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>
   <LineChart fx:id="scopeView" prefHeight="299.0" prefWidth="453.0">
     <xAxis>
       <NumberAxis label="time" side="BOTTOM" fx:id="xAxis" />
     </xAxis>
     <yAxis>
       <NumberAxis fx:id="yAxis" label="voltage" side="LEFT" />
     </yAxis>
   </LineChart>
   <ToolBar prefHeight="40.0" prefWidth="200.0">
     <items>
          <Button onAction="#onHelloButtonClick" text="Hello!" />
         <TextField fx:id="frequency" prefHeight="25.0" prefWidth="59.0" text="60" />
     </items>
   </ToolBar>
</VBox>
